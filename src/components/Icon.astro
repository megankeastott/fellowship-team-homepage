---
// Small inline-SVG icon set — replaces the old external imgur PNGs so the
// site loads lighter and doesn't depend on a third-party image host.
// All icons draw with `currentColor` so they inherit the surrounding color.
interface Props {
  name?: string | null;
  size?: number;
  class?: string;
}
const { name, size = 26, class: className } = Astro.props;

const stroke = {
  fill: 'none',
  stroke: 'currentColor',
  'stroke-width': '1.5',
  'stroke-linecap': 'round',
  'stroke-linejoin': 'round',
} as const;
---
{name === 'candle' && (
  <svg class={className} width={size} height={size} viewBox="0 0 24 24" {...stroke}>
    <path d="M12 3c1.4 1.2 1.4 2.7 0 4-1.4-1.3-1.4-2.8 0-4z" />
    <rect x="9" y="9" width="6" height="11" rx="1" />
    <path d="M12 7v2" />
  </svg>
)}
{name === 'tome' && (
  <svg class={className} width={size} height={size} viewBox="0 0 24 24" {...stroke}>
    <path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H12v16H6.5A2.5 2.5 0 0 0 4 21.5z" />
    <path d="M20 5.5A2.5 2.5 0 0 0 17.5 3H12v16h5.5A2.5 2.5 0 0 1 20 21.5z" />
  </svg>
)}
{name === 'door' && (
  <svg class={className} width={size} height={size} viewBox="0 0 24 24" {...stroke}>
    <path d="M5 20a7 7 0 0 1 14 0z" />
    <path d="M5 20V13a7 7 0 0 1 14 0v7" />
    <circle cx="15" cy="14" r="1" />
  </svg>
)}
{name === 'quill' && (
  <svg class={className} width={size} height={size} viewBox="0 0 24 24" {...stroke}>
    <path d="M4 20c6-1 9-4 13-13 0 0-9 1-12 8" />
    <path d="M4 20l4-4" />
  </svg>
)}
{name === 'lantern' && (
  <svg class={className} width={size} height={size} viewBox="0 0 24 24" {...stroke}>
    <path d="M9 4h6" />
    <path d="M8 8h8l1 9a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2z" />
    <path d="M12 2v2" />
  </svg>
)}
{name === 'mug' && (
  <svg class={className} width={size} height={size} viewBox="0 0 24 24" {...stroke}>
    <path d="M6 8h11v7a4 4 0 0 1-4 4H10a4 4 0 0 1-4-4z" />
    <path d="M17 10h2a2 2 0 0 1 0 5h-2" />
  </svg>
)}
{name === 'compass' && (
  <svg class={className} width={size} height={size} viewBox="0 0 24 24" {...stroke}>
    <circle cx="12" cy="12" r="9" />
    <path d="M15.5 8.5l-2 5-5 2 2-5z" />
  </svg>
)}
{name === 'pipe' && (
  <svg class={className} width={size} height={size} viewBox="0 0 24 24" {...stroke}>
    <path d="M3 11h9v2a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4z" />
    <path d="M12 11V7a3 3 0 0 1 3-3" />
  </svg>
)}
