---
// Decorative section icons — the custom art made for this site.
// Lazy-loaded so they don't block initial paint.
interface Props {
  name?: string | null;
  class?: string;
}
const { name, class: className } = Astro.props;

const ASSETS: Record<string, { src: string; cls?: string; alt: string }> = {
  candle: { src: 'https://i.imgur.com/ZNXhhfb.png', cls: 'candle-img', alt: 'Candle' },
  tome: { src: 'https://i.imgur.com/u4SC2da.png', alt: 'Tome' },
  door: { src: 'https://i.imgur.com/qQoxF1V.png', alt: 'Round door' },
  quill: { src: 'https://i.imgur.com/7VdlgsC.png', alt: 'Quill' },
  lantern: { src: 'https://i.imgur.com/jslbRTo.png', alt: 'Lantern' },
  mug: { src: 'https://i.imgur.com/fNOsDGD.png', alt: 'Mug' },
  compass: { src: 'https://i.imgur.com/6EgjrMK.png', alt: 'Compass' },
  pipe: { src: 'https://i.imgur.com/gWtRr4r.png', alt: 'Pipe' },
};

const asset = name ? ASSETS[name] : null;
---
{asset && (
  <img
    src={asset.src}
    alt={asset.alt}
    loading="lazy"
    decoding="async"
    class:list={['asset-icon', asset.cls, className]}
  />
)}
