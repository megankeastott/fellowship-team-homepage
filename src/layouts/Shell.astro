---
import '../styles/global.css';
import Fireflies from '../components/Fireflies.astro';
import LeafDivider from '../components/LeafDivider.astro';
import { NAV_ITEMS, routeUrl } from '../config/site';

interface Props {
  title: string;
  activeSlug?: string;
}
const { title, activeSlug } = Astro.props;
const pageTitle = `The Fellowship of the Fix — ${title}`;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="The Fellowship of the Fix — Operations Support, Tutor Team home base." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="vine-edge"></div>
    <Fireflies />

    <div class="container">
      <header class="title-wrap">
        <img class="corner-fl" src="https://i.imgur.com/rnnAXuv.png" alt="" loading="lazy" decoding="async" />
        <img class="corner-fr" src="https://i.imgur.com/zbG7R47.png" alt="" loading="lazy" decoding="async" />
        <img class="title-sigil-img" src="https://i.imgur.com/Sz7FZ5y.png" alt="Leaf of Lórien" loading="lazy" decoding="async" />
        <img class="title-art" src="https://i.imgur.com/FQnG6gJ.png" alt="The Fellowship of the Fix" decoding="async" />
        <div class="sub">Operations Support — Tutor Team</div>
        <div class="inscription">— one team to find them, one team to help them all —</div>
        <div class="title-rule"></div>
      </header>

      <nav class="text-nav">
        {NAV_ITEMS.map((item, i) => (
          <>
            {i > 0 && <span class="sep">✦</span>}
            {item.slug === activeSlug ? (
              <a class="current" aria-current="page">{item.label}</a>
            ) : (
              <a href={routeUrl(item.slug)}>{item.label}</a>
            )}
          </>
        ))}
      </nav>

      <div class="flourish">✦ • ✦ • ✦</div>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <div class="footer-leaf"><LeafDivider /></div>
        <div class="footer-text">
          In a hole in the ground there lived a hobbit — and from that hole, a fellowship was forged.
        </div>
      </footer>
    </div>
  </body>
</html>
