---
// Lightweight firefly canvas. Fewer particles than the original, pauses when
// the tab is hidden, and is disabled entirely for prefers-reduced-motion
// (handled in CSS by hiding the canvas).
---
<canvas id="fireflies" aria-hidden="true"></canvas>

<script>
  (function () {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (reduce.matches) return;

    const canvas = document.getElementById('fireflies') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const COUNT = 22;
    let W = 0, H = 0, pageH = 0, raf = 0;
    const flies: {
      x: number; y: number; vx: number; vy: number;
      r: number; phase: number; speed: number;
    }[] = [];

    const getPageH = () => Math.max(document.documentElement.scrollHeight, window.innerHeight);
    function resize() {
      W = canvas.width = window.innerWidth;
      H = canvas.height = window.innerHeight;
      pageH = getPageH();
    }
    resize();
    window.addEventListener('resize', resize);
    setInterval(() => { pageH = getPageH(); }, 3000);

    for (let i = 0; i < COUNT; i++) {
      flies.push({
        x: Math.random() * W,
        y: Math.random() * pageH,
        vx: (Math.random() - 0.5) * 0.28,
        vy: (Math.random() - 0.5) * 0.28,
        r: 1.4 + Math.random() * 1.3,
        phase: Math.random() * Math.PI * 2,
        speed: 0.008 + Math.random() * 0.012,
      });
    }

    function draw() {
      ctx!.clearRect(0, 0, W, H);
      const scrollY = window.scrollY || 0;
      for (const f of flies) {
        f.phase += f.speed;
        const alpha = 0.22 + Math.abs(Math.sin(f.phase)) * 0.5;
        f.x += f.vx; f.y += f.vy;
        f.vx += (Math.random() - 0.5) * 0.02;
        f.vy += (Math.random() - 0.5) * 0.02;
        f.vx = Math.max(-0.45, Math.min(0.45, f.vx));
        f.vy = Math.max(-0.45, Math.min(0.45, f.vy));
        if (f.x < -20) f.x = W + 20;
        if (f.x > W + 20) f.x = -20;
        if (f.y < -20) f.y = pageH + 20;
        if (f.y > pageH + 20) f.y = -20;

        const sy = f.y - scrollY;
        if (sy < -30 || sy > H + 30) continue;

        const g = ctx!.createRadialGradient(f.x, sy, 0, f.x, sy, f.r * 9);
        g.addColorStop(0, `rgba(214,192,112,${alpha * 0.3})`);
        g.addColorStop(0.4, `rgba(200,170,80,${alpha * 0.1})`);
        g.addColorStop(1, 'rgba(180,160,80,0)');
        ctx!.fillStyle = g;
        ctx!.beginPath();
        ctx!.arc(f.x, sy, f.r * 9, 0, Math.PI * 2);
        ctx!.fill();

        ctx!.fillStyle = `rgba(240,222,150,${alpha})`;
        ctx!.beginPath();
        ctx!.arc(f.x, sy, f.r, 0, Math.PI * 2);
        ctx!.fill();
      }
      raf = requestAnimationFrame(draw);
    }
    function start() { if (!raf) raf = requestAnimationFrame(draw); }
    function stop() { cancelAnimationFrame(raf); raf = 0; }
    document.addEventListener('visibilitychange', () => {
      document.hidden ? stop() : start();
    });
    start();
  })();
</script>
