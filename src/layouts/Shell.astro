---
import '../styles/global.css';
import Fireflies from '../components/Fireflies.astro';
import LeafDivider from '../components/LeafDivider.astro';
import { NAV_ITEMS, routeUrl } from '../config/site';

interface Props {
  title: string;
  activeSlug?: string;
}
const { title, activeSlug } = Astro.props;
const pageTitle = `The Fellowship of the Fix — ${title}`;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="The Fellowship of the Fix — Operations Support, Tutor Team home base." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="vine-edge"></div>
    <Fireflies />

    <div class="container">
      <header class="title-wrap">
        <span class="title-sigil" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="#dab766" stroke-width="1.4"
               stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2c3 4 3 9 0 13-3-4-3-9 0-13z" />
            <path d="M12 15v7" />
            <path d="M12 18c-2 0-3.5-1-4.5-2.5M12 18c2 0 3.5-1 4.5-2.5" />
          </svg>
        </span>
        <div class="site-title">The Fellowship <span class="of">of the</span> Fix</div>
        <div class="sub">Operations Support — Tutor Team</div>
        <div class="inscription">— one team to find them, one team to help them all —</div>
        <div class="title-rule"></div>
      </header>

      <nav class="text-nav">
        {NAV_ITEMS.map((item, i) => (
          <>
            {i > 0 && <span class="sep">✦</span>}
            {item.slug === activeSlug ? (
              <a class="current" aria-current="page">{item.label}</a>
            ) : (
              <a href={routeUrl(item.slug)}>{item.label}</a>
            )}
          </>
        ))}
      </nav>

      <div class="flourish">✦ • ✦ • ✦</div>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <LeafDivider class="footer-leaf-svg" />
        <div class="footer-text">
          In a hole in the ground there lived a hobbit — and from that hole, a fellowship was forged.
        </div>
      </footer>
    </div>
  </body>
</html>

<style>
  .footer-leaf-svg { width: 220px; height: 16px; opacity: 0.5; margin: 0 auto 10px; display: block; }
</style>
